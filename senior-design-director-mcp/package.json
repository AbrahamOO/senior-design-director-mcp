{
  "name": "senior-design-director-mcp",
  "version": "1.3.11",
  "description": "MCP server for professional design guidance. Works with Claude Code, Cursor, Windsurf, Codex, and any MCP client. Project discovery, design systems, color palettes, accessibility, performance, iOS HIG, and Material Design 3.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "senior-design-director-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "node scripts/preflight.mjs && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "design",
    "design-system",
    "design-tokens",
    "accessibility",
    "wcag",
    "web-design",
    "ui-ux",
    "color-palette",
    "typography",
    "ios-hig",
    "material-design",
    "performance",
    "core-web-vitals",
    "claude",
    "cursor",
    "ai-tools",
    "codex"
  ],
  "author": "Abraham Ojo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbrahamOO/senior-design-director-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/AbrahamOO/senior-design-director-mcp/issues"
  },
  "homepage": "https://github.com/AbrahamOO/senior-design-director-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
